# Reference template for required frontend variables.
# For local development copy these keys to .env.local instead.

NEXT_PUBLIC_API_BASE_URL=https://your-api.example.com

# Required: Supabase project settings (Supabase dashboard -> Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

NEXT_PUBLIC_SITE_URL=https://your-dashboard.example.com
